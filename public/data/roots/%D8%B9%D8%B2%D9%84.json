[{"s":2,"a":222,"i":7,"text":"فَٱعْتَزِلُوا۟","lemma":"اعْتَزَلَ","gloss":"so keep away (from)"},{"s":4,"a":90,"i":25,"text":"ٱعْتَزَلُوكُمْ","lemma":"اعْتَزَلَ","gloss":"they withdraw from you"},{"s":4,"a":91,"i":17,"text":"يَعْتَزِلُوكُمْ","lemma":"اعْتَزَلَ","gloss":"they withdraw from you"},{"s":11,"a":42,"i":12,"text":"مَعْزِلٍۢ","lemma":"مَعْزِل","gloss":"apart"},{"s":18,"a":16,"i":2,"text":"ٱعْتَزَلْتُمُوهُمْ","lemma":"اعْتَزَلَ","gloss":"you withdraw from them"},{"s":19,"a":48,"i":1,"text":"وَأَعْتَزِلُكُمْ","lemma":"اعْتَزَلَ","gloss":"And I will leave you"},{"s":19,"a":49,"i":2,"text":"ٱعْتَزَلَهُمْ","lemma":"اعْتَزَلَ","gloss":"he left them"},{"s":26,"a":212,"i":4,"text":"لَمَعْزُولُونَ","lemma":"مَعْزُول","gloss":"(are) surely banished"},{"s":33,"a":51,"i":12,"text":"عَزَلْتَ","lemma":"عَزَلْ","gloss":"you (had) set aside "},{"s":44,"a":21,"i":5,"text":"فَٱعْتَزِلُونِ","lemma":"اعْتَزَلَ","gloss":"then leave me alone"}]