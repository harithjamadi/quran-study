[{"s":5,"a":3,"i":14,"text":"وَٱلْمُتَرَدِّيَةُ","lemma":"مُتَرَدِّيَة","gloss":"and that which has a fatal fall"},{"s":6,"a":137,"i":9,"text":"لِيُرْدُوهُمْ","lemma":"أَرْدَى","gloss":"so that they may ruin them"},{"s":20,"a":16,"i":10,"text":"فَتَرْدَىٰ","lemma":"تَرْدَى","gloss":"lest you perish"},{"s":37,"a":56,"i":5,"text":"لَتُرْدِينِ","lemma":"أَرْدَى","gloss":"ruined me"},{"s":41,"a":23,"i":6,"text":"أَرْدَىٰكُمْ","lemma":"أَرْدَى","gloss":"It has ruined you"},{"s":92,"a":11,"i":6,"text":"تَرَدَّىٰٓ","lemma":"تَرَدَّى","gloss":"he falls"}]