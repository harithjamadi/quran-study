[{"s":3,"a":26,"i":9,"text":"وَتَنزِعُ","lemma":"نَزَعَ","gloss":"and You take away"},{"s":3,"a":152,"i":11,"text":"وَتَنَـٰزَعْتُمْ","lemma":"تَنازَعُ","gloss":"and you fell into dispute"},{"s":4,"a":59,"i":12,"text":"تَنَـٰزَعْتُمْ","lemma":"تَنازَعُ","gloss":"you disagree"},{"s":7,"a":27,"i":11,"text":"يَنزِعُ","lemma":"نَزَعَ","gloss":"stripping"},{"s":7,"a":43,"i":1,"text":"وَنَزَعْنَا","lemma":"نَزَعَ","gloss":"And We will remove"},{"s":7,"a":108,"i":1,"text":"وَنَزَعَ","lemma":"نَزَعَ","gloss":"And he drew out"},{"s":8,"a":43,"i":11,"text":"وَلَتَنَـٰزَعْتُمْ","lemma":"تَنازَعُ","gloss":"and surely you would have disputed"},{"s":8,"a":46,"i":5,"text":"تَنَـٰزَعُوا۟","lemma":"تَنازَعُ","gloss":"dispute"},{"s":11,"a":9,"i":7,"text":"نَزَعْنَـٰهَا","lemma":"نَزَعَ","gloss":"We withdraw it"},{"s":15,"a":47,"i":1,"text":"وَنَزَعْنَا","lemma":"نَزَعَ","gloss":"And We (will) remove"},{"s":18,"a":21,"i":15,"text":"يَتَنَـٰزَعُونَ","lemma":"تَنازَعُ","gloss":"they disputed"},{"s":19,"a":69,"i":2,"text":"لَنَنزِعَنَّ","lemma":"نَزَعَ","gloss":"surely, We will drag out"},{"s":20,"a":62,"i":1,"text":"فَتَنَـٰزَعُوٓا۟","lemma":"تَنازَعُ","gloss":"Then they disputed"},{"s":22,"a":67,"i":8,"text":"يُنَـٰزِعُنَّكَ","lemma":"يُنازِعُ","gloss":"So let them not dispute with you"},{"s":26,"a":33,"i":1,"text":"وَنَزَعَ","lemma":"نَزَعَ","gloss":"And he drew out"},{"s":28,"a":75,"i":1,"text":"وَنَزَعْنَا","lemma":"نَزَعَ","gloss":"And We will draw forth"},{"s":52,"a":23,"i":1,"text":"يَتَنَـٰزَعُونَ","lemma":"تَنازَعُ","gloss":"They will pass to one another"},{"s":54,"a":20,"i":1,"text":"تَنزِعُ","lemma":"نَزَعَ","gloss":"Plucking out"},{"s":70,"a":16,"i":1,"text":"نَزَّاعَةًۭ","lemma":"نَزّاعَة","gloss":"A remover"},{"s":79,"a":1,"i":1,"text":"وَٱلنَّـٰزِعَـٰتِ","lemma":"نازِعَة","gloss":"By those who extract"}]