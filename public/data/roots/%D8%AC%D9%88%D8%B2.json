[{"s":2,"a":249,"i":31,"text":"جَاوَزَهُۥ","lemma":"جاوَزَ","gloss":"he crossed it"},{"s":7,"a":138,"i":1,"text":"وَجَـٰوَزْنَا","lemma":"جاوَزَ","gloss":"And We led across"},{"s":10,"a":90,"i":1,"text":"۞ وَجَـٰوَزْنَا","lemma":"جاوَزَ","gloss":"And We took across"},{"s":18,"a":62,"i":2,"text":"جَاوَزَا","lemma":"جاوَزَ","gloss":"they had passed beyond"},{"s":46,"a":16,"i":8,"text":"وَنَتَجَاوَزُ","lemma":"نَتَجاوَزُ","gloss":"and We will overlook"}]