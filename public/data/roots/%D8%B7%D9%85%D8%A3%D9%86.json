[{"s":2,"a":260,"i":15,"text":"لِّيَطْمَئِنَّ","lemma":"اطْمَأَنَّ","gloss":"to satisfy"},{"s":3,"a":126,"i":7,"text":"وَلِتَطْمَئِنَّ","lemma":"اطْمَأَنَّ","gloss":"and to reassure"},{"s":4,"a":103,"i":11,"text":"ٱطْمَأْنَنتُمْ","lemma":"اطْمَأَنَّ","gloss":"you are secure"},{"s":5,"a":113,"i":6,"text":"وَتَطْمَئِنَّ","lemma":"اطْمَأَنَّ","gloss":"and satisfy"},{"s":8,"a":10,"i":6,"text":"وَلِتَطْمَئِنَّ","lemma":"اطْمَأَنَّ","gloss":"and so that might be at rest"},{"s":10,"a":7,"i":9,"text":"وَٱطْمَأَنُّوا۟","lemma":"اطْمَأَنَّ","gloss":"and feel satisfied"},{"s":13,"a":28,"i":3,"text":"وَتَطْمَئِنُّ","lemma":"اطْمَأَنَّ","gloss":"and find satisfaction"},{"s":13,"a":28,"i":10,"text":"تَطْمَئِنُّ","lemma":"اطْمَأَنَّ","gloss":"find satisfaction"},{"s":16,"a":106,"i":11,"text":"مُطْمَئِنٌّۢ","lemma":"مُطْمَئِنّ","gloss":"(is) content"},{"s":16,"a":112,"i":7,"text":"مُّطْمَئِنَّةًۭ","lemma":"مُطْمَئِنَّة","gloss":"and content"},{"s":17,"a":95,"i":8,"text":"مُطْمَئِنِّينَ","lemma":"مُطْمَئِنّ","gloss":"securely"},{"s":22,"a":11,"i":11,"text":"ٱطْمَأَنَّ","lemma":"اطْمَأَنَّ","gloss":"he is content"},{"s":89,"a":27,"i":3,"text":"ٱلْمُطْمَئِنَّةُ","lemma":"مُطْمَئِنَّة","gloss":"who is satisfied"}]