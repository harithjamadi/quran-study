[{"s":4,"a":10,"i":12,"text":"وَسَيَصْلَوْنَ","lemma":"يَصْلَى","gloss":"and they will be burned"},{"s":4,"a":30,"i":7,"text":"نُصْلِيهِ","lemma":"أُصْلِي","gloss":"We (will) cast him"},{"s":4,"a":56,"i":6,"text":"نُصْلِيهِمْ","lemma":"أُصْلِي","gloss":"We will burn them"},{"s":4,"a":115,"i":17,"text":"وَنُصْلِهِۦ","lemma":"أُصْلِي","gloss":"and We will burn him"},{"s":14,"a":29,"i":2,"text":"يَصْلَوْنَهَا ۖ","lemma":"يَصْلَى","gloss":"(in) it they will burn"},{"s":17,"a":18,"i":16,"text":"يَصْلَىٰهَا","lemma":"يَصْلَى","gloss":"he will burn"},{"s":19,"a":70,"i":8,"text":"صِلِيًّۭا","lemma":"صِلِيّ","gloss":"(of) being burnt"},{"s":27,"a":7,"i":16,"text":"تَصْطَلُونَ","lemma":"تَصْطَلُ","gloss":"warm yourselves"},{"s":28,"a":29,"i":27,"text":"تَصْطَلُونَ","lemma":"تَصْطَلُ","gloss":"warm yourselves"},{"s":36,"a":64,"i":1,"text":"ٱصْلَوْهَا","lemma":"يَصْلَى","gloss":"Burn therein"},{"s":37,"a":163,"i":4,"text":"صَالِ","lemma":"صال","gloss":"(is) to burn"},{"s":38,"a":56,"i":2,"text":"يَصْلَوْنَهَا","lemma":"يَصْلَى","gloss":"they will burn therein"},{"s":38,"a":59,"i":9,"text":"صَالُوا۟","lemma":"صالُوا","gloss":"(will) burn"},{"s":52,"a":16,"i":1,"text":"ٱصْلَوْهَا","lemma":"يَصْلَى","gloss":"Burn in it"},{"s":56,"a":94,"i":1,"text":"وَتَصْلِيَةُ","lemma":"تَصْلِيَة","gloss":"And burning"},{"s":58,"a":8,"i":36,"text":"يَصْلَوْنَهَا ۖ","lemma":"يَصْلَى","gloss":"they will burn in it"},{"s":69,"a":31,"i":3,"text":"صَلُّوهُ","lemma":"صَلُّ","gloss":"burn him"},{"s":74,"a":26,"i":1,"text":"سَأُصْلِيهِ","lemma":"أُصْلِي","gloss":"Soon I will drive him"},{"s":82,"a":15,"i":1,"text":"يَصْلَوْنَهَا","lemma":"يَصْلَى","gloss":"They will burn (in) it"},{"s":83,"a":16,"i":3,"text":"لَصَالُوا۟","lemma":"صالُوا","gloss":"(surely) will burn"},{"s":84,"a":12,"i":1,"text":"وَيَصْلَىٰ","lemma":"يَصْلَى","gloss":"And he will burn"},{"s":87,"a":12,"i":2,"text":"يَصْلَى","lemma":"يَصْلَى","gloss":"will burn"},{"s":88,"a":4,"i":1,"text":"تَصْلَىٰ","lemma":"يَصْلَى","gloss":"They will b