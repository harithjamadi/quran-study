[{"s":15,"a":12,"i":2,"text":"نَسْلُكُهُۥ","lemma":"سَلَكَ","gloss":"We let it enter"},{"s":16,"a":69,"i":6,"text":"فَٱسْلُكِى","lemma":"سَلَكَ","gloss":"and follow"},{"s":20,"a":53,"i":6,"text":"وَسَلَكَ","lemma":"سَلَكَ","gloss":"and inserted"},{"s":23,"a":27,"i":13,"text":"فَٱسْلُكْ","lemma":"سَلَكَ","gloss":"then put"},{"s":26,"a":200,"i":2,"text":"سَلَكْنَـٰهُ","lemma":"سَلَكَ","gloss":"We have inserted it"},{"s":28,"a":32,"i":1,"text":"ٱسْلُكْ","lemma":"سَلَكَ","gloss":"Insert"},{"s":39,"a":21,"i":9,"text":"فَسَلَكَهُۥ","lemma":"سَلَكَ","gloss":"and He makes it flow"},{"s":69,"a":32,"i":7,"text":"فَٱسْلُكُوهُ","lemma":"سَلَكَ","gloss":"insert him"},{"s":71,"a":20,"i":1,"text":"لِّتَسْلُكُوا۟","lemma":"سَلَكَ","gloss":"That you may go along"},{"s":72,"a":17,"i":8,"text":"يَسْلُكْهُ","lemma":"سَلَكَ","gloss":"He will make him enter"},{"s":72,"a":27,"i":7,"text":"يَسْلُكُ","lemma":"سَلَكَ","gloss":"makes to march"},{"s":74,"a":42,"i":2,"text":"سَلَكَكُمْ","lemma":"سَلَكَ","gloss":"led you"}]