[{"s":14,"a":34,"i":11,"text":"تُحْصُوهَآ ۗ","lemma":"أَحْصَى","gloss":"you will (be able to) count them"},{"s":16,"a":18,"i":6,"text":"تُحْصُوهَآ ۗ","lemma":"أَحْصَى","gloss":"you could enumerate them"},{"s":18,"a":12,"i":6,"text":"أَحْصَىٰ","lemma":"أَحْصَى","gloss":"best calculated"},{"s":18,"a":49,"i":19,"text":"أَحْصَىٰهَا ۚ","lemma":"أَحْصَى","gloss":"has enumerated it"},{"s":19,"a":94,"i":2,"text":"أَحْصَىٰهُمْ","lemma":"أَحْصَى","gloss":"He has enumerated them"},{"s":36,"a":12,"i":11,"text":"أَحْصَيْنَـٰهُ","lemma":"أَحْصَى","gloss":"We have enumerated it"},{"s":58,"a":6,"i":8,"text":"أَحْصَىٰهُ","lemma":"أَحْصَى","gloss":"Allah has recorded it"},{"s":65,"a":1,"i":8,"text":"وَأَحْصُوا۟","lemma":"أَحْصَى","gloss":"and keep count"},{"s":72,"a":28,"i":10,"text":"وَأَحْصَىٰ","lemma":"أَحْصَى","gloss":"and He takes account"},{"s":73,"a":20,"i":23,"text":"تُحْصُوهُ","lemma":"أَحْصَى","gloss":"you count it"},{"s":78,"a":29,"i":3,"text":"أَحْصَيْنَـٰهُ","lemma":"أَحْصَى","gloss":"We have enumerated it"}]