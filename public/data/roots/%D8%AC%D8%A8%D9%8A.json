[{"s":3,"a":179,"i":23,"text":"يَجْتَبِى","lemma":"اجْتَبَى","gloss":"chooses"},{"s":6,"a":87,"i":5,"text":"وَٱجْتَبَيْنَـٰهُمْ","lemma":"اجْتَبَى","gloss":"and We chose them"},{"s":7,"a":203,"i":7,"text":"ٱجْتَبَيْتَهَا ۚ","lemma":"اجْتَبَى","gloss":"you devised it"},{"s":12,"a":6,"i":2,"text":"يَجْتَبِيكَ","lemma":"اجْتَبَى","gloss":"will choose you"},{"s":16,"a":121,"i":3,"text":"ٱجْتَبَىٰهُ","lemma":"اجْتَبَى","gloss":"He chose him"},{"s":19,"a":58,"i":21,"text":"وَٱجْتَبَيْنَآ ۚ","lemma":"اجْتَبَى","gloss":"and We chose"},{"s":20,"a":122,"i":2,"text":"ٱجْتَبَـٰهُ","lemma":"اجْتَبَى","gloss":"chose him"},{"s":22,"a":78,"i":7,"text":"ٱجْتَبَىٰكُمْ","lemma":"اجْتَبَى","gloss":"(has) chosen you"},{"s":28,"a":57,"i":14,"text":"يُجْبَىٰٓ","lemma":"يُجْبَى","gloss":"are brought"},{"s":34,"a":13,"i":9,"text":"كَٱلْجَوَابِ","lemma":"جَواب","gloss":"like reservoirs"},{"s":42,"a":13,"i":31,"text":"يَجْتَبِىٓ","lemma":"اجْتَبَى","gloss":"chooses"},{"s":68,"a":50,"i":1,"text":"فَٱجْتَبَـٰهُ","lemma":"اجْتَبَى","gloss":"But chose him"}]